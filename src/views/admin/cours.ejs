<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=<device-width>, initial-scale=1.0">
    <title>Cours</title>
</head>
<body>
    <h1>Cours_dashboard</h1>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nom</th>
                        <th>Description</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% courses.forEach(c => { %>
                        <tr>
                            <td><%= c.id %></td>
                            <td><%= c.name %></td>
                            <td><%= c.description %></td>
                            <td>
                                <div class="actions">
                                    <a class="btn btn-secondary" href="/admin/courses/edit/<%= c.id %>">Edit</a>
                                    <form action="/admin/courses/delete/<%= c.id %>" method="POST" onsubmit="return confirm('Delete this course?');">
                                        <button class="btn btn-danger" type="submit">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>


   

    
</body>
</html>