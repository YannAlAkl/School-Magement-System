<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Enrôlement & Paiement</title>

  <!-- Adjust path if your static is mounted differently -->
  <link rel="stylesheet" href="/css/style.css" />
</head>

<body>
  <!-- Prefer absolute include -->
 

  <main class="container">
    <div class="page-header">
      <h1>Enrôlement & Paiement</h1>
      <p class="muted">Assigner un étudiant à un cours et enregistrer un paiement.</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>

    <div class="grid-2">
      <!-- Enrollment Card -->
      <section class="card">
        <div class="card-title">
          <h2>1) Enrôler un étudiant</h2>
          <p class="muted">Sélectionnez l’étudiant et le cours à assigner.</p>
        </div>

        <form action="/admin/enrolement/add" method="POST" class="form">
          <div class="form-row">
            <div class="form-group">
              <label for="student_id">Étudiant</label>
              <select id="student_id" name="student_id" required>
                <option value="" disabled selected>Choisir un étudiant…</option>
                <% if (students && students.length) { %>
                  <% students.forEach(s => { %>
                    <option value="<%= s.id %>">
                      <%= s.username %><% if (s.email) { %> — <%= s.email %><% } %>
                    </option>
                  <% }) %>
                <% } %>
              </select>
              <small class="hint">Seuls les utilisateurs avec le rôle <strong>student</strong> apparaissent ici.</small>
            </div>

            <div class="form-group">
              <label for="course_title">Cours</label>
              <select id="course_title" name="course_title" required>
                <option value="" disabled selected>Choisir un cours…</option>
                <% if (courses && courses.length) { %>
                  <% courses.forEach(c => { %>
                    <option value="<%= c.title %>"><%= c.title %></option>
                  <% }) %>
                <% } %>
              </select>
              <small class="hint">Astuce: vous pouvez gérer les cours depuis “Courses”.</small>
            </div>
          </div>

          <div class="divider"></div>

          <div class="form-row">
            <div class="form-group">
              <label for="enroll_status">Statut</label>
              <select id="enroll_status" name="enroll_status" required>
                <option value="active" selected>Active</option>
                <option value="pending">Pending</option>
                <option value="suspended">Suspended</option>
              </select>
            </div>

            <div class="form-group">
              <label for="enroll_date">Date d’enrôlement</label>
              <input type="date" id="enroll_date" name="enroll_date" required />
            </div>
          </div>

          <div class="actions">
            <button type="submit" class="btn btn-primary">Enrôler</button>
            <button type="button" class="btn btn-warning">Modifier</button>
            <button type="button" class="btn btn-danger">Supprimer</button>
            <button type="reset" class="btn btn-ghost">Réinitialiser</button>
          </div>
        </form>
      </section>

      <!-- Payment Card -->
      <section class="card">
        <div class="card-title">
          <h2> 2) Enregistrer un paiement</h2>
          <p class="muted">Associez un paiement à un étudiant (et éventuellement à un cours).</p>
        </div>

        <form action="/admin/payments/add" method="POST" class="form">
          <div class="form-row">
            <div class="form-group">
              <label for="pay_student_username">Étudiant</label>
              <select id="pay_student_username" name="student_username" required>
                <option value="" disabled selected>Choisir un étudiant…</option>
                <% if (students && students.length) { %>
                  <% students.forEach(s => { %>
                    <option value="<%= s.username %>">
                      <%= s.username %><% if (s.email) { %> — <%= s.email %><% } %>
                    </option>
                  <% }) %>
                <% } %>
              </select>
            </div>

            <div class="form-group">
              <label for="pay_course_title">Cours (optionnel)</label>
              <select id="pay_course_title" name="course_title"></select>
                <option value="" selected>Aucun (paiement global)</option>
                <% if (courses && courses.length) { %>
                  <% courses.forEach(c => { %>
                    <option value="<%= c.title %>"><%= c.title %></option>
                  <% }) %>
                <% } %>
              </select>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="amount">Montant</label>
              <input type="number" id="amount" name="amount" min="0" step="0.01" placeholder="Ex: 150.00" required />
            </div>

            <div class="form-group">
              <label for="currency">Devise</label>
              <select id="currency" name="currency" required>
                <option value="TND">TND</option>
                <option value="EUR">EUR</option>
                <option value="CAD">CAD</option>
                <option value="USD">USD</option>
              </select>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="method">Méthode</label>
              <select id="method" name="method" required>
                <option value="cash">Cash</option>
                <option value="card">Carte</option>
                <option value="transfer">Virement</option>
                <option value="cheque">Chèque</option>
              </select>
            </div>

            <div class="form-group">
              <label for="payment_date">Date</label>
              <input type="date" id="payment_date" name="payment_date" required />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="payment_status">Statut</label>
              <select id="payment_status" name="status" required>
                <option value="paid" selected>Paid</option>
                <option value="pending">Pending</option>
                <option value="failed">Failed</option>
                <option value="refunded">Refunded</option>
              </select>
            </div>

            <div class="form-group">
              <label for="reference">Référence (optionnel)</label>
              <input type="text" id="reference" name="reference" placeholder="Ex: Reçu #, transaction ID..." />
            </div>
          </div>

          <div class="form-group">
            <label for="note">Note (optionnel)</label>
            <textarea id="note" name="note" rows="3" placeholder="Commentaire interne…"></textarea>
          </div>

          <div class="actions">
            <button type="submit" class="btn btn-primary">Enregistrer paiement</button>
            <button type="button" class="btn btn-warning">Modifier</button>
            <button type="button" class="btn btn-danger">Supprimer</button>
            <button type="reset" class="btn btn-ghost">Réinitialiser</button>
          </div>
        </form>
      </section>
    </div>
  </main>

  <script>
    // Auto-fill today's date for convenience
    (function () {
      const today = new Date().toISOString().slice(0, 10);
      const enrollDate = document.getElementById('enroll_date');
      const payDate = document.getElementById('payment_date');
      if (enrollDate && !enrollDate.value) enrollDate.value = today;
      if (payDate && !payDate.value) payDate.value = today;
    })();
  </script>
</body>
</html>
