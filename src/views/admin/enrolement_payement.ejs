<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Enrôlement & Frais</title>

  <link rel="stylesheet" href="/css/style.css" />

  <style>
    .status {
      padding: 0.25rem 0.5rem;
      border-radius: 4px;
      font-size: 0.875rem;
      font-weight: 500;
      text-transform: capitalize;
    }
    .status-active {
      background-color: #d4edda;
      color: #155724;
    }
    .status-pending {
      background-color: #fff3cd;
      color: #856404;
    }
    .status-rejected {
      background-color: #f8d7da;
      color: #721c24;
    }
    .status-completed {
      background-color: #d1ecf1;
      color: #0c5460;
    }
    .btn-sm {
      padding: 0.25rem 0.5rem;
      font-size: 0.875rem;
    }
    .table-container {
      overflow-x: auto;
    }
  </style>
</head>

<body>

  <!-- Empêche les erreurs si le contrôleur n'envoie pas les variables -->
  <% var selectedStudent = typeof selectedStudent !== "undefined" ? selectedStudent : null; %>
  <% var totals = typeof totals !== "undefined" ? totals : []; %>
  <% var enrollments = typeof enrollments !== "undefined" ? enrollments : []; %>

  <main class="container">

    <div class="page-header">
      <h1>Enrôlement & Frais</h1>
      <p class="muted">L’admin enrôle l’élève et le système calcule automatiquement le total des frais.</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <% if (success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>

    <div class="grid-2">

      <!-- SECTION 1 : ENRÔLEMENT -->
<section class="card">
  <div class="card-title">
    <h2>1) Enrôler un élève à un cours</h2>
    <p class="muted">Sélectionnez l’élève, le cours et définissez son prix.</p>
  </div>

  <form action="/admin/enrolement/add" method="POST" class="form">

    <div class="form-group">
      <label for="student_id">Élève</label>
      <select id="student_id" name="student_id" required>
        <option value="" disabled selected>Choisir un élève…</option>
        <% students.forEach(s => { %>
          <option value="<%= s.id %>" data-username="<%= s.username %>">
            <%= s.username %> <% if (s.email) { %> — <%= s.email %> <% } %>
          </option>
        <% }) %>
      </select>
      <input type="hidden" id="student_username" name="student_username" />
    </div>

    <div class="form-group">
      <label for="course_title">Cours</label>
      <select id="course_title" name="course_title" required>
        <option value="" disabled selected>Choisir un cours…</option>
        <% courses.forEach(c => { %>
          <option value="<%= c.title %>">
            <%= c.title %>
          </option>
        <% }) %>
      </select>
    </div>

    <!-- 🔥 CHAMP AJOUTÉ : PRIX DU COURS -->
    <div class="form-group">
      <label for="course_price">Prix du cours</label>
      <input type="number" id="course_price" name="course_price" min="0" step="0.01" placeholder="Ex : 150.00" required />
    </div>

    <div class="form-group">
      <label for="enroll_date">Date d’enrôlement</label>
      <input type="date" id="enroll_date" name="enroll_date" required />
    </div>

    <div class="form-group">
      <label for="enroll_status">Statut</label>
      <select id="enroll_status" name="enroll_status">
        <option value="active">Active</option>
        <option value="pending">Pending</option>
      </select>
    </div>

    <div class="actions">
      <button type="submit" class="btn btn-primary">Enrôler</button>
      <button type = "edit" class="btn btn-warning">Modifier</button>     
     <button type = "delete" class="btn btn-danger">Supprimer</button>
    </div>
  </form>
</section>

      <!-- SECTION 2 : FRAIS TOTAUX AUTOMATIQUES -->
      <section class="card">
        <div class="card-title">
          <h2>2) Frais totaux de l’élève</h2>
          <p class="muted">
            Le total est calculé automatiquement selon les cours auxquels l’élève est enrôlé.
          </p>
        </div>

        <!-- Formulaire pour choisir l’élève -->
        <form action="/admin/fees/show" method="GET" class="form">

          <div class="form-group">
            <label for="fee_student_id">Élève</label>
            <select id="fee_student_id" name="student_id" required>
              <option value="" disabled selected>Choisir un élève…</option>
              <% students.forEach(s => { %>
                <option value="<%= s.id %>">
                  <%= s.username %> <% if (s.email) { %> — <%= s.email %> <% } %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="actions">
            <button type="submit" class="btn btn-primary">Afficher les frais</button>
            <button type = "edit" class="btn btn-warning">Modifier</button>     
            <button type = "delete" class="btn btn-danger">Supprimer</button>
          </div>
        </form>
        <!-- Tableau des frais -->
        <div class="result-box">
          <h3>
            Frais totaux pour :
            <%= selectedStudent ? selectedStudent.username : "—" %>
          </h3>
          <table class="table">
            <thead>
              <tr>
                <th>Session</th>
                <th>Total</th>
                <th>Cours inclus</th>
              </tr>
            </thead>

            <tbody>
              <% if (totals.length > 0) { %>

                <% totals.forEach(t => { %>
                  <tr>
                    <td><%= t.session %></td>
                    <td><%= t.total %> $</td>
                    <td>
                      <ul>
                        <% t.courses.forEach(c => { %>
                          <li><%= c %></li>
                        <% }) %>
                      </ul>
                    </td>
                  </tr>
                <% }) %>

              <% } else { %>
                <tr>
                  <td colspan="3" class="muted">Aucune donnée disponible.</td>
                </tr>
              <% } %>
            </tbody>

          </table>

          <!-- BOUTON POUR ENVOYER LES FRAIS AU PORTAIL ÉLÈVE -->
          <form action="/admin/fees/publish" method="POST" class="form" style="margin-top: 1rem;">
            <input type="hidden" name="student_id" value="<%= selectedStudent ? selectedStudent.id : '' %>">

            <button type="submit" class="btn btn-success"></button>
              <%= !selectedStudent ? "disabled" : "" %>
              Envoyer les frais au portail élève
            </button>
          </form>

        </div>

      </section>

      <!-- SECTION 3 : LISTE DES ENRÔLEMENTS EXISTANTS -->
      <section class="card" style="grid-column: 1 / -1;">
        <div class="card-title">
          <h2>3) Enrôlements existants</h2>
          <p class="muted">Gérer les enrôlements existants : modifier ou supprimer.</p>
        </div>

        <div class="table-container">
          <table class="table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Élève</th>
                <th>Cours</th>
                <th>Statut</th>
                <th>Date d'enrôlement</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (enrollments.length > 0) { %>
                <% enrollments.forEach(enrollment => { %>
                  <tr>
                    <td><%= enrollment.id %></td>
                    <td><%= enrollment.student_username %></td>
                    <td><%= enrollment.course_title %></td>
                    <td>
                      <span class="status status-<%= enrollment.enroll_status %>">
                        <%= enrollment.enroll_status %>
                      </span>
                    </td>
                    <td><%= enrollment.enroll_date ? new Date(enrollment.enroll_date).toLocaleDateString('fr-FR') : '-' %></td>
                    <td>
                      <button type="button" class="btn btn-sm btn-warning" onclick="editEnrollment(<%= enrollment.id %>)">
                        Modifier
                      </button>
                      <form action="/admin/enrolement/delete/<%= enrollment.id %>" method="POST" style="display: inline;" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet enrôlement ?')">
                        <button type="submit" class="btn btn-sm btn-danger">
                          Supprimer
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="6" class="muted">Aucun enrôlement trouvé.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </section>

    </div>
  </main>

  <script>
    (function () {
      const today = new Date().toISOString().slice(0, 10);
      const enrollDate = document.getElementById('enroll_date');
      if (enrollDate && !enrollDate.value) enrollDate.value = today;

      // Remplir automatiquement student_username quand student_id change
      const studentIdSelect = document.getElementById('student_id');
      const studentUsernameInput = document.getElementById('student_username');

      studentIdSelect.addEventListener('change', function() {
        const selectedOption = this.options[this.selectedIndex];
        const username = selectedOption.getAttribute('data-username');
        studentUsernameInput.value = username || '';
      });
    })();

    // Fonction pour ouvrir le modal d'édition
    function editEnrollment(enrollmentId) {
      // Trouver l'enrollment dans la liste
      <% enrollments.forEach(enrollment => { %>
        if (<%= enrollment.id %> === enrollmentId) {
          // Remplir le formulaire d'ajout avec les données existantes
          document.getElementById('student_id').value = '<%= enrollment.student_id %>';
          document.getElementById('student_username').value = '<%= enrollment.student_username %>';
          document.getElementById('course_title').value = '<%= enrollment.course_title %>';
          document.getElementById('enroll_status').value = '<%= enrollment.enroll_status %>';
          document.getElementById('enroll_date').value = '<%= enrollment.enroll_date ? new Date(enrollment.enroll_date).toISOString().slice(0, 10) : '' %>';

          // Changer le formulaire pour l'édition
          const form = document.querySelector('form[action="/admin/enrolement/add"]');
          form.action = '/admin/enrolement/edit/' + enrollmentId;
          form.querySelector('button[type="submit"]').textContent = 'Modifier l\'enrôlement';

          // Ajouter un bouton annuler
          let cancelBtn = form.querySelector('.cancel-btn');
          if (!cancelBtn) {
            cancelBtn = document.createElement('button');
            cancelBtn.type = 'button';
            cancelBtn.className = 'btn btn-secondary cancel-btn';
            cancelBtn.textContent = 'Annuler';
            cancelBtn.onclick = resetForm;
            form.querySelector('.actions').appendChild(cancelBtn);
          }

          // Scroll vers le formulaire
          form.scrollIntoView({ behavior: 'smooth' });
        }
      <% }) %>
    }

    // Fonction pour réinitialiser le formulaire
    function resetForm() {
      const form = document.querySelector('form');
      form.action = '/admin/enrolement/add';
      form.querySelector('button[type="submit"]').textContent = 'Enrôler';
      form.reset();

      // Supprimer le bouton annuler
      const cancelBtn = form.querySelector('.cancel-btn');
      if (cancelBtn) {
        cancelBtn.remove();
      }

      // Remettre la date d'aujourd'hui
      const today = new Date().toISOString().slice(0, 10);
      const enrollDate = document.getElementById('enroll_date');
      if (enrollDate) enrollDate.value = today;
    }
  </script>
</body>
</html>